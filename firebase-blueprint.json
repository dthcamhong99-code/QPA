{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A project managed in the QPA system.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project." },
        "year": { "type": "number", "description": "Year the project was implemented." },
        "planNumber": { "type": "string", "description": "Project plan number." },
        "projectName": { "type": "string", "description": "Name of the project." },
        "totalInvestment": { "type": "number", "description": "Total investment amount." },
        "scale": { "type": "string", "description": "Project scale." },
        "status": { "type": "string", "enum": ["registered", "unregistered", "paused", "cancelled"], "description": "Current status of the project." },
        "pcgdDocument": { "type": "string", "description": "PCGD document." },
        "evnhcmcDocument": { "type": "string", "description": "EVNHCMC document." },
        "notes": { "type": "string", "description": "Additional notes." },
        "uid": { "type": "string", "description": "Owner UID of the project." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the project was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when the project was last updated." }
      },
      "required": ["id", "year", "planNumber", "projectName", "totalInvestment", "status", "uid", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "User email address." },
        "displayName": { "type": "string", "description": "User display name." },
        "photoURL": { "type": "string", "description": "User profile photo URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role." }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all projects."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    }
  }
}
